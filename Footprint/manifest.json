{
  "name": "Footprint",
   "icons": {
    "16": "icon/capybara_black_-removebg-preview.png",
    "32": "icon/capybara_black_-removebg-preview.png",
    "48": "icon/capybara_black_-removebg-preview.png",
    "128": "icon/capybara_black_-removebg-preview.png"
  },
  "description": "Local website-risk, download-safety, identity and combined cyber-hygiene awareness extension. FYP for Rivyashiniy Jayaraj TP071899.",
  "version": "2.2.1",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "downloads",
    "notifications"
  ],
  "host_permissions": [
    "https://www.virustotal.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon/capybara_black_-removebg-preview.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
